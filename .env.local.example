# ============================================================
# Cloudflare R2 — Video Storage
# ============================================================
# Lấy từ Cloudflare dashboard:
# 1. R2 → Manage R2 API Tokens → Create API Token
#    + Permissions: Object Read & Write
#    + (chọn bucket cụ thể hoặc tất cả)
# 2. Sau khi tạo, lưu lại Access Key ID, Secret Access Key, Account ID
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Tên bucket bạn đã tạo trên R2
R2_BUCKET=

# Public URL của bucket (sau khi enable Public Access trong settings bucket)
# Format: https://pub-<hash>.r2.dev
# KHÔNG có dấu / ở cuối
R2_PUBLIC_URL=

# ============================================================
# Cloudflare Stream — Autoplay Video Processing
# ============================================================
# Customer subdomain trong Cloudflare Stream dashboard.
# Format: customer-xxxxxxxx.cloudflarestream.com
NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER_CODE=

# Server-side token để admin/cron tự copy video R2 sang Stream.
# Token permissions: Account > Stream > Edit.
# Không đặt token này với tiền tố NEXT_PUBLIC_.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Secret để Vercel Cron gọi /api/admin/stream-sync an toàn.
# Tạo bằng: openssl rand -hex 32
CRON_SECRET=

# ============================================================
# Admin Authentication
# ============================================================
# Mật khẩu để đăng nhập trang /admin
ADMIN_PASSWORD=

# Secret để ký HTTP-only cookie (random ≥ 32 ký tự)
# Tạo bằng: openssl rand -hex 32
ADMIN_SECRET=

# ============================================================
# Hero Video (homepage)
# ============================================================
# URL public của video chạy ở trang chủ (có thể là URL R2 sau khi upload)
# Nếu để trống sẽ fallback về YouTube iframe cũ
NEXT_PUBLIC_HERO_VIDEO_URL=
